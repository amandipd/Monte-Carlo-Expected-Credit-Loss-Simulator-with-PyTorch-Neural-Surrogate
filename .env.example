# Copy to .env and adjust. Used by loop_calc, vectorized_calc, multicore_calc, ecl_engine.
# Simulation size — change to compare runtimes (e.g. 1000000 for quick runs)
N_LOANS=100000000

# Core simulation (PD = 1 - exp(-HAZARD_RATE * TIME_HORIZON))
HAZARD_RATE=0.05
TIME_HORIZON=1.0

# ECL engine — portfolio loss parameters
BASE_HAZARD_RATE=0.05
AVG_EXPOSURE=250000
LGD=0.45

# Baseline macro environment (neutral stress; hazard multipliers = 1.0)
MACRO_BASELINE_UNEMPLOYMENT=4.0
MACRO_BASELINE_INTEREST=3.0
MACRO_BASELINE_HPI=100.0

# Macro sampling / clipping bounds (for synthetic data and inference)
MACRO_UNEMPLOYMENT_MIN=2.0
MACRO_UNEMPLOYMENT_MAX=15.0
MACRO_INTEREST_MIN=0.0
MACRO_INTEREST_MAX=12.0
MACRO_HPI_MIN=70.0
MACRO_HPI_MAX=130.0

# Synthetic dataset generation
N_SAMPLES=1000
TRAINING_N_LOANS=500000
TRAINING_LABEL_SEED=42

# Surrogate evaluation gates
EVAL_MAE_THRESHOLD=0.05
EVAL_SPOT_CHECK_TOLERANCE=0.10
EVAL_SPOT_CHECK_COUNT=5

# Redis (distributed simulation queue)
REDIS_HOST=localhost
REDIS_PORT=6379
N_JOBS=10
